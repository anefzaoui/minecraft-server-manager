{{> page-header heading="BACKUPS" sub="Every archive across all servers, with reason and retention tracking."}}

{{#if backups.length}}
<div class="mb-4 flex flex-wrap items-center gap-2">
  <select class="input w-auto" id="backups-filter-server" data-label="Filter by server">
    <option value="">All servers</option>
    {{#each servers}}<option value="{{id}}">{{name}}</option>{{/each}}
  </select>
  <select class="input w-auto" id="backups-filter-reason" data-label="Filter by reason">
    <option value="">All reasons</option>
    <option value="manual">Manual</option>
    <option value="scheduled">Scheduled</option>
    <option value="pre-update">Pre-update</option>
  </select>
  <span class="ml-auto text-sm text-ink-faint" id="backups-total" data-count="{{totals.count}}" data-bytes="{{totals.bytes}}">Total: {{bytes totals.bytes}} in {{totals.count}} archive{{#if (ne totals.count 1)}}s{{/if}}</span>
</div>

<div class="card overflow-x-auto">
  <table class="table-base" id="backups-table">
    <thead><tr><th>Server</th><th>Archive</th><th>Reason</th><th class="text-right">Size</th><th class="text-right">Created</th><th class="text-right">Actions</th></tr></thead>
    <tbody>
      {{#each backups}}
        <tr data-backup-row data-backup-id="{{id}}" data-server-id="{{serverId}}" data-server-name="{{server}}" data-file="{{file}}" data-size="{{size}}" data-reason="{{reason}}">
          <td class="whitespace-nowrap"><a class="text-link hover:underline" href="/servers/{{serverId}}/backups">{{server}}</a></td>
          {{! w-full + max-w-0 so long archive names truncate instead of pushing Actions off-screen. }}
          <td class="w-full max-w-0"><span class="block truncate font-mono text-xs" title="{{file}}">{{file}}</span></td>
          <td><span class="badge {{#if (eq reason 'pre-update')}}badge-warn{{/if}}">{{reason}}</span></td>
          <td class="whitespace-nowrap text-right text-ink-faint">{{bytes size}}</td>
          <td class="whitespace-nowrap text-right text-ink-faint" data-ts="{{ts}}">{{ts}}</td>
          <td class="text-right"><div class="inline-flex gap-1">
            <button class="btn btn-ghost btn-sm text-warn" data-backup-action="restore" data-tip="Restore (stops the server, safety backup taken first)">{{{icon 'undo-2' 'size-3.5'}}}</button>
            <button class="btn btn-ghost btn-sm" data-backup-action="download" data-tip="Download archive">{{{icon 'download' 'size-3.5'}}}</button>
            <button class="btn btn-ghost btn-sm text-danger" data-backup-action="delete" data-tip="Delete ({{bytes size}} freed)" aria-label="Delete {{file}}">{{{icon 'trash-2' 'size-3.5'}}}</button>
          </div></td>
        </tr>
      {{/each}}
    </tbody>
  </table>
  <div class="hidden p-8 text-center text-sm text-ink-faint" id="backups-no-match">No backups match these filters.</div>
</div>
{{else}}
  {{> empty-state iconName='archive' title='No backups yet' message='Create one from a server&apos;s Backups tab — scheduled and pre-update backups will also collect here, with reason and retention tracking.'}}
{{/if}}
<script type="module" src="/js/pages/backups.js"></script>

<div class="mb-6 grid grid-cols-2 gap-3 sm:grid-cols-4 {{#if serversOnly}}hidden{{/if}}">
  <div class="card p-4">
    <div class="text-xs text-ink-faint">Servers online</div>
    {{! Green only when something IS online — 0/3 in success green lied. }}
    <div class="mt-1 text-2xl font-bold tabular-nums {{#if totals.running}}text-ok{{/if}}">{{totals.running}}<span class="text-base font-medium text-ink-faint"> / {{totals.total}}</span></div>
  </div>
  <div class="card p-4">
    <div class="text-xs text-ink-faint">Players connected</div>
    <div class="mt-1 text-2xl font-bold tabular-nums">{{totals.players}}</div>
  </div>
  <div class="card p-4">
    <div class="text-xs text-ink-faint">Updates available</div>
    <div class="mt-1 text-2xl font-bold tabular-nums {{#if totals.updates}}text-warn{{/if}}">{{totals.updates}}</div>
  </div>
  <div class="card p-4">
    <div class="text-xs text-ink-faint">Docker</div>
    <div class="mt-1 flex items-center gap-2 text-sm font-semibold text-ink-faint" id="docker-status">
      <span class="status-dot relative bg-stone-500"></span> Checking…
    </div>
  </div>
</div>

<div id="docker-warning" class="notice notice-danger mb-4 hidden">
  {{{icon 'triangle-alert' 'size-4 mt-0.5 shrink-0 text-danger'}}}
  <div>
    <span class="font-semibold text-danger">Docker isn’t reachable.</span>
    <span id="docker-warning-reason">Start Docker, then reload — creating or starting servers needs the daemon running.</span>
  </div>
</div>

{{#unless noServers}}
<div class="mb-4 flex flex-wrap items-center gap-2">
  <input class="input max-w-xs" placeholder="Search servers, tags…" id="server-filter">
  {{! Visible "Sort" label: only the first option carried a "Sort:" prefix, so
      the closed trigger read context-free once anything else was picked. }}
  <label class="text-xs text-ink-faint" for="server-sort">Sort</label>
  <select class="input w-auto" id="server-sort" data-label="Sort servers">
    <option value="status" {{#if (eq sort 'status')}}selected{{/if}}>Status</option>
    <option value="name" {{#if (eq sort 'name')}}selected{{/if}}>Name</option>
    <option value="size" {{#if (eq sort 'size')}}selected{{/if}}>Size</option>
    <option value="started" {{#if (eq sort 'started')}}selected{{/if}}>Last started</option>
    <option value="created" {{#if (eq sort 'created')}}selected{{/if}}>Created</option>
  </select>
  <div class="seg ml-auto" role="group" aria-label="View">
    <button class="seg-btn" id="view-grid" aria-pressed="false" data-tip="Grid view">{{{icon 'layout-grid' 'size-4'}}}</button>
    <button class="seg-btn" id="view-list" aria-pressed="false" data-tip="List view">{{{icon 'list' 'size-4'}}}</button>
  </div>
</div>

{{/unless}}

{{#if noServers}}
  {{> empty-state iconName='pickaxe' title='No servers yet' message='Create your first Minecraft server — pick a server type and version, or start from a blueprint. You will be playing in minutes.' ctaHref='/servers/new' ctaLabel='Create your first server'}}
{{else}}
<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3" id="server-grid">
  {{#each servers}}
    {{> server-card}}
  {{/each}}

  <a href="/servers/new" class="grid min-h-44 place-items-center rounded-lg border-2 border-dashed border-line text-ink-faint transition hover:border-grass-600 hover:text-ok">
    <div class="grid place-items-center text-center">
      {{{icon 'plus' 'size-8'}}}
      <div class="mt-2 text-sm font-medium">Create a server</div>
    </div>
  </a>
</div>
{{/if}}

<div class="mt-8 {{#if serversOnly}}hidden{{/if}}">
  <div class="mb-3 flex items-center justify-between">
    <h2 class="font-semibold">Recent activity</h2>
    <a href="/activity" class="text-sm text-link hover:underline">View all →</a>
  </div>
  <div class="card divide-y divide-line">
    {{#each activity}}
      <div class="flex items-center gap-3 px-4 py-3 text-sm">
        <span class="badge shrink-0">{{type}}</span>
        <span class="min-w-0 flex-1 truncate">{{summary}}</span>
        {{! deleted-server names are plain faint text — link-styled dead spans read as broken. }}
        {{#if serverId}}<a href="/servers/{{serverId}}" class="hidden shrink-0 text-xs text-link hover:underline sm:block">{{server}}</a>{{else}}<span class="hidden shrink-0 text-xs text-ink-faint sm:block">{{server}}</span>{{/if}}
        <span class="shrink-0 text-xs text-ink-faint" data-ts-ago="{{ts}}">{{ts}}</span>
      </div>
    {{else}}
      <div class="px-4 py-8 text-center text-sm text-ink-faint">No activity yet — actions on your servers will show up here.</div>
    {{/each}}
  </div>
</div>
<script type="module" src="/js/pages/dashboard.js"></script>

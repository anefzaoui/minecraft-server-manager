<div data-backups-server="{{server.id}}" data-server-status="{{server.status}}" class="contents">
<div class="mb-4 flex flex-wrap items-center gap-2">
  <p class="text-sm text-ink-faint">Retention: keep 10 scheduled + all pre-update backups</p>
  <button class="btn btn-primary btn-sm ml-auto" id="bk-now">{{{icon 'save' 'size-3.5'}}} Back up now</button>
</div>
{{#if backups.length}}
<div class="card overflow-x-auto">
  <table class="table-base" id="bk-table">
    <thead><tr><th>Archive</th><th>Reason</th><th class="text-right">Size</th><th class="text-right">Created</th><th class="text-right">Actions</th></tr></thead>
    <tbody>
      {{#each backups}}
        <tr data-backup-row data-backup-id="{{id}}" data-file="{{file}}" data-size="{{size}}">
          <td class="font-mono text-xs">{{file}}</td>
          <td><span class="badge {{#if (eq reason 'pre-update')}}badge-warn{{/if}}">{{reason}}</span></td>
          <td class="text-right text-ink-faint">{{bytes size}}</td>
          <td class="text-right text-ink-faint">{{ts}}</td>
          <td class="text-right"><div class="inline-flex gap-1">
            <button class="btn btn-ghost btn-sm" data-backup-restore data-tip="Stops the server, restores this archive, restarts">{{{icon 'undo-2' 'size-3.5'}}} Restore</button>
            <a class="btn btn-ghost btn-sm" href="/api/backups/{{id}}/download" data-tip="Download archive" aria-label="Download {{file}}">{{{icon 'download' 'size-3.5'}}}</a>
            <button class="btn btn-ghost btn-sm text-danger" data-backup-delete data-tip="Delete ({{bytes size}} freed)" aria-label="Delete {{file}}">{{{icon 'x' 'size-3.5'}}}</button>
          </div></td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{else}}
  {{> empty-state iconName='archive' title='No backups yet' message='Hit Back up now for the first one — scheduled and pre-update backups will also collect here automatically.'}}
{{/if}}
</div>
<script type="module" src="/js/pages/server-backups.js"></script>

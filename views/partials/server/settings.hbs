<div class="grid gap-4 lg:grid-cols-2" data-settings-server="{{server.id}}" data-settings-icon="{{server.icon}}" data-settings-accent="{{server.accent}}" data-settings-tags="{{json server.tags}}" data-settings-env="{{settingsEnv}}">
  <div class="card p-4">
    <h3 class="mb-4 font-semibold">Identity</h3>
    <div class="space-y-4">
      <div>
        <label class="label" for="st-name">Display name</label>
        <input class="input" id="st-name" value="{{server.name}}">
        <p class="help">Rename freely — folders, container names and history stay keyed to the internal ID.</p>
      </div>
      <div>
        <label class="label" for="st-desc">Description</label>
        <textarea class="input" id="st-desc" rows="3">{{server.description}}</textarea>
        <p class="help">Markdown supported; shown on the Overview tab.</p>
      </div>
      <div>
        <label class="label" for="st-motd">MOTD <span class="text-xs font-normal text-ink-faint">— shown in every player's server list</span></label>
        <input class="input font-mono" id="st-motd" value="{{motd}}" autocomplete="off">
        <div class="console mt-2 py-2 text-sm" id="st-motd-preview"></div>
        <p class="help">Applies on the next restart.</p>
      </div>
      {{! Both pickers use ONE selection language: aria-pressed + the theme-aware
          .swatch ring (the old white ring was invisible on the light theme, and
          the icon picker used a different green-border treatment one row over).
          The current stock icon is marked in place — no duplicate "current" tile. }}
      <div class="grid grid-cols-2 gap-3">
        <div>
          <span class="label">Icon</span>
          <div class="flex flex-wrap gap-1.5" id="st-icon-picker">
            {{#if (startsWith server.icon 'custom:')}}
              <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="{{server.icon}}" data-tip="Current custom icon" aria-pressed="true"><img src="{{iconSrc server.icon}}" alt="" class="size-full rounded-sm" onerror="this.onerror=null;this.src='/icons/servers/grass.png'"></button>
            {{/if}}
            <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="grass" aria-pressed="{{eq server.icon 'grass'}}"><img src="/icons/servers/grass.png" alt="Grass block" class="size-full rounded-sm"></button>
            <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="creeper" aria-pressed="{{eq server.icon 'creeper'}}"><img src="/icons/servers/creeper.png" alt="Creeper" class="size-full rounded-sm"></button>
            <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="diamond" aria-pressed="{{eq server.icon 'diamond'}}"><img src="/icons/servers/diamond.png" alt="Diamond" class="size-full rounded-sm"></button>
            <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="portal" aria-pressed="{{eq server.icon 'portal'}}"><img src="/icons/servers/portal.png" alt="Nether portal" class="size-full rounded-sm"></button>
            <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="chest" aria-pressed="{{eq server.icon 'chest'}}"><img src="/icons/servers/chest.png" alt="Chest" class="size-full rounded-sm"></button>
            <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="sword" aria-pressed="{{eq server.icon 'sword'}}"><img src="/icons/servers/sword.png" alt="Sword" class="size-full rounded-sm"></button>
            <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="potion" aria-pressed="{{eq server.icon 'potion'}}"><img src="/icons/servers/potion.png" alt="Potion" class="size-full rounded-sm"></button>
            <button class="swatch grid size-9 place-items-center bg-inset p-1" data-pick-icon="tnt" aria-pressed="{{eq server.icon 'tnt'}}"><img src="/icons/servers/tnt.png" alt="TNT" class="size-full rounded-sm"></button>
            <button class="grid size-9 place-items-center rounded-sm border border-dashed border-line-strong text-ink-faint transition hover:border-stone-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-diamond-400" id="st-icon-upload" data-tip="Upload a custom icon (PNG/SVG)">{{{icon 'upload' 'size-4'}}}</button>
          </div>
        </div>
        <div>
          <span class="label">Accent color</span>
          {{! Amethyst is a deliberate off-ramp from the four semantic ramps —
              it's identity decoration from Minecraft source material, not meaning. }}
          <div class="flex flex-wrap items-center gap-1.5" id="st-accent-picker">
            <button class="swatch size-9" style="background: #3fa62b" data-pick-accent="#3fa62b" data-tip="Grass" aria-pressed="false"></button>
            <button class="swatch size-9" style="background: #21a7ab" data-pick-accent="#21a7ab" data-tip="Diamond" aria-pressed="false"></button>
            <button class="swatch size-9" style="background: #e5484d" data-pick-accent="#e5484d" data-tip="Redstone" aria-pressed="false"></button>
            <button class="swatch size-9" style="background: #e99417" data-pick-accent="#e99417" data-tip="Gold" aria-pressed="false"></button>
            <button class="swatch size-9" style="background: #9a5cc6" data-pick-accent="#9a5cc6" data-tip="Amethyst" aria-pressed="false"></button>
          </div>
        </div>
      </div>
      <div>
        <label class="label" for="st-tag-input">Tags</label>
        {{! Chips are rendered by server-settings.js from data-settings-tags — no server copy, or they double up. }}
        <div class="flex flex-wrap items-center gap-1.5" id="st-tags">
          <input class="input w-28" id="st-tag-input" placeholder="add tag…">
        </div>
      </div>
      <div>
        <label class="label" for="st-notes">Private notes <span class="badge ml-1">admin only</span></label>
        <textarea class="input font-mono text-xs" id="st-notes" rows="2" placeholder="Scratchpad — never shown to viewers">{{server.notes}}</textarea>
      </div>
      <div class="space-y-2.5 border-t border-line pt-3">
        <label class="flex items-center justify-between gap-3 text-sm">
          <span>Start on panel boot</span>
          <span class="msm-toggle"><input type="checkbox" id="st-autostart" {{#if server.autoStart}}checked{{/if}}><span></span></span>
        </label>
        <label class="flex items-center justify-between gap-3 text-sm">
          <span>Auto-restart on crash <span class="block text-xs text-ink-faint">with backoff; gives up after 3 rapid crashes</span></span>
          <span class="msm-toggle"><input type="checkbox" id="st-autorestart" {{#if server.autoRestart}}checked{{/if}}><span></span></span>
        </label>
      </div>
    </div>
  </div>

  <div class="space-y-4">
    <div class="card p-4">
      <h3 class="mb-4 font-semibold">Resources</h3>
      <div class="space-y-4">
        <div>
          <label class="label" for="st-heap">Java heap <span class="ml-1 font-mono text-[11px] text-ink-faint">MEMORY</span></label>
          <div class="flex items-center gap-3">
            <input type="range" min="1024" max="16384" step="512" value="{{server.resources.heapMb}}" id="st-heap" class="msm-range flex-1" data-out="out-heap" data-unit=" MB">
            <span class="w-20 text-right font-mono text-sm" id="out-heap">{{server.resources.heapMb}} MB</span>
          </div>
          <p class="help">RAM the Minecraft/Java process may use. The image passes this to the JVM as both initial and max heap.</p>
        </div>
        <div>
          <label class="label" for="st-cmem">Container memory limit <span class="ml-1 font-mono text-[11px] text-ink-faint">HostConfig.Memory</span></label>
          <div class="flex items-center gap-3">
            <input type="range" min="1024" max="20480" step="512" value="{{server.resources.containerMemoryMb}}" id="st-cmem" class="msm-range msm-range-alt flex-1" data-out="out-cmem" data-unit=" MB">
            <span class="w-20 text-right font-mono text-sm" id="out-cmem">{{server.resources.containerMemoryMb}} MB</span>
          </div>
          <p class="help">Hard cap enforced by Docker. Keep it 25–50% above the heap — Java needs off-heap room, and hitting this cap kills the container (OOM).</p>
        </div>
        <div class="rounded-md border p-2.5 text-xs" id="st-headroom" aria-live="polite"></div>
        <div>
          <label class="label" for="st-cpu">CPU limit</label>
          <div class="flex items-center gap-3">
            <input type="range" min="0" max="16" step="0.5" value="{{server.resources.cpus}}" id="st-cpu" class="msm-range msm-range-alt flex-1" data-out="out-cpu" data-unit=" cores" data-zero="∞">
            <span class="w-20 text-right font-mono text-sm" id="out-cpu">{{#if server.resources.cpus}}{{server.resources.cpus}} cores{{else}}∞{{/if}}</span>
          </div>
          <p class="help">0 = unlimited. When capped, the server slows down instead of being killed.</p>
        </div>
        <div>
          <label class="label" for="st-quota">Disk quota <span class="badge ml-1">panel-enforced</span></label>
          <div class="flex items-center gap-3">
            <input type="range" min="0" max="200" step="5" value="{{quotaGb}}" id="st-quota" class="msm-range flex-1" data-out="out-quota" data-unit=" GB" data-zero="off">
            <span class="w-20 text-right font-mono text-sm" id="out-quota">{{quotaGb}} GB</span>
          </div>
          <p class="help">Soft quota checked by the storage indexer — Docker can't cap bind-mount size. Over quota, disk-growing actions are blocked; optional strict mode stops the server.</p>
        </div>
      </div>
    </div>

    <div class="card p-4">
      <h3 class="mb-3 font-semibold">Update policy</h3>
      <div class="space-y-2 text-sm">
        <label class="flex items-center gap-2.5"><input type="radio" name="up" value="manual" class="msm-radio" {{#if (eq server.updatePolicy 'manual')}}checked{{/if}}> Manual only <span class="text-xs text-ink-faint">— never touch my versions</span></label>
        <label class="flex items-center gap-2.5"><input type="radio" name="up" value="notify" class="msm-radio" {{#if (eq server.updatePolicy 'notify')}}checked{{/if}}> Notify me <span class="text-xs text-ink-faint">— badge when updates exist</span></label>
        <label class="flex items-center gap-2.5"><input type="radio" name="up" value="auto" class="msm-radio" {{#if (eq server.updatePolicy 'auto')}}checked{{/if}}> Auto-update <span class="text-xs text-ink-faint">— with automatic pre-update backup</span></label>
      </div>
    </div>

    <div class="card p-4">
      <h3 class="mb-3 font-semibold">Blueprint &amp; maintenance</h3>
      <div class="flex flex-wrap gap-2">
        <button class="btn" id="st-export-bp">{{{icon 'drafting-compass' 'size-4'}}} Export as blueprint</button>
        <button class="btn" id="st-clone">{{{icon 'copy' 'size-4'}}} Clone server</button>
        <button class="btn" data-server-action="recreate" data-server-id="{{server.id}}" data-server-name="{{server.name}}" data-tip="Applies pending env/resource changes">{{{icon 'wrench' 'size-4'}}} Recreate container</button>
      </div>
      {{! Destruction lives behind its own divider, never one accidental click
          from the safe maintenance actions above. }}
      <div class="mt-3 flex items-center justify-between gap-3 border-t border-line pt-3">
        <p class="text-xs text-ink-faint">Deletes the container, world, mods and config. Backups are kept.</p>
        <button class="btn btn-danger shrink-0" data-server-action="delete" data-server-id="{{server.id}}" data-server-name="{{server.name}}">{{{icon 'trash-2' 'size-4'}}} Delete server</button>
      </div>
    </div>
  </div>
</div>

<div class="mt-4 flex justify-end gap-2">
  <button class="btn" id="st-discard">Discard</button>
  <button class="btn btn-primary" id="st-save">Save changes</button>
</div>

<script type="module" src="/js/pages/server-settings.js"></script>

{{! One field-catalog entry → labeled control. Context: a catalog field object. }}
{{#if (eq type 'boolean')}}
  {{! Booleans: single row — text block left, toggle right (like Settings). }}
  <div class="flex items-start justify-between gap-6 py-3.5 first:pt-1 last:pb-1">
    <div class="min-w-0">
      <span class="flex flex-wrap items-baseline gap-x-2 gap-y-1 text-sm font-medium text-ink">
        {{label}}
        <span class="font-mono text-[11px] font-normal text-ink-faint">{{key}}</span>
        {{#if note}}<span class="badge badge-warn font-normal normal-case tracking-normal">{{note}}</span>{{/if}}
        {{#if danger}}<span class="badge badge-danger font-normal normal-case tracking-normal">caution</span>{{/if}}
      </span>
      <p class="mt-1 max-w-prose text-xs leading-relaxed text-ink-faint">{{help}}</p>
    </div>
    <label class="msm-toggle mt-0.5 shrink-0">
      <input type="checkbox" data-catalog-key="{{key}}" data-catalog-scope="{{scope}}" data-catalog-type="boolean" data-catalog-default="{{default}}" {{#if default}}checked{{/if}}>
      <span></span>
    </label>
  </div>
{{else}}
  <div class="space-y-1.5 py-3.5 first:pt-1 last:pb-1">
    <label class="flex flex-wrap items-baseline gap-x-2 gap-y-1 text-sm font-medium text-ink">
      {{label}}
      <span class="font-mono text-[11px] font-normal text-ink-faint">{{key}}</span>
      {{#if unit}}<span class="text-xs font-normal text-ink-faint">({{unit}})</span>{{/if}}
      {{#if note}}<span class="badge badge-warn font-normal normal-case tracking-normal">{{note}}</span>{{/if}}
      {{#if danger}}<span class="badge badge-danger font-normal normal-case tracking-normal">caution</span>{{/if}}
    </label>

    {{#if (eq type 'enum')}}
      <select class="input max-w-sm" data-catalog-key="{{key}}" data-catalog-scope="{{scope}}" data-catalog-type="enum" data-catalog-default="{{default}}" data-label="{{label}}">
        {{#unless default}}<option value="">(image default)</option>{{/unless}}
        {{#each options}}
          <option value="{{value}}" {{#if (eq value ../default)}}selected{{/if}} {{#if desc}}data-desc="{{desc}}"{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    {{else if (or (eq type 'number') (or (eq type 'size-mb') (eq type 'range')))}}
      <input class="input max-w-48 font-mono" type="number" inputmode="numeric"
        data-catalog-key="{{key}}" data-catalog-scope="{{scope}}" data-catalog-type="number" data-catalog-default="{{default}}"
        {{#if min}}min="{{min}}"{{/if}} {{#if max}}max="{{max}}"{{/if}} {{#if step}}step="{{step}}"{{/if}}
        placeholder="{{#if default}}{{default}}{{else}}image default{{/if}}">
    {{else if (eq type 'list')}}
      <textarea class="input max-w-xl font-mono text-xs" rows="2"
        data-catalog-key="{{key}}" data-catalog-scope="{{scope}}" data-catalog-type="list"
        placeholder="one entry per line"></textarea>
    {{else}}
      <input class="input max-w-xl font-mono" type="text"
        data-catalog-key="{{key}}" data-catalog-scope="{{scope}}" data-catalog-type="text" data-catalog-default="{{default}}"
        placeholder="{{#if default}}{{default}}{{else}}image default{{/if}}">
    {{/if}}

    <p class="max-w-prose text-xs leading-relaxed text-ink-faint">{{help}}</p>
  </div>
{{/if}}

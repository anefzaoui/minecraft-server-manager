{{> page-header heading="ACTIVITY" sub="Every action across every server — who did what, when, with the receipts."}}

{{#if (or events.length (or filters.q (or filters.server filters.type)))}}
<form class="mb-4 flex flex-wrap items-center gap-2" method="get" action="/activity" id="activity-filters">
  <input class="input max-w-xs" name="q" value="{{filters.q}}" placeholder="Search events…" autocomplete="off">
  <select class="input w-auto" name="server" data-label="Filter by server">
    <option value="">All servers</option>
    {{#each servers}}<option value="{{id}}" {{#if (eq id ../filters.server)}}selected{{/if}}>{{name}}</option>{{/each}}
  </select>
  <select class="input w-auto" name="type" data-label="Filter by type">
    <option value="">All types</option>
    {{#each types}}<option value="{{this}}" {{#if (eq this ../filters.type)}}selected{{/if}}>{{this}}</option>{{/each}}
  </select>
  <button class="btn btn-sm" type="submit">{{{icon 'search' 'size-3.5'}}} Apply</button>
  <div class="ml-auto flex gap-1">
    <a class="btn btn-sm" href="/api/events/export?format=csv{{exportQs}}" data-tip="Export the filtered events as CSV">{{{icon 'download' 'size-3.5'}}} CSV</a>
    <a class="btn btn-sm" href="/api/events/export?format=json{{exportQs}}" data-tip="Export the filtered events as JSON">{{{icon 'download' 'size-3.5'}}} JSON</a>
  </div>
</form>

<div class="card">
  <ol class="divide-y divide-line">
    {{#each events}}
      <li class="flex flex-wrap items-center gap-2 p-3 text-sm">
        <span class="badge shrink-0 bg-inset text-ink-soft">{{type}}</span>
        <span class="min-w-0 flex-1">{{summary}}</span>
        {{#if serverId}}
          <a href="/servers/{{serverId}}" class="shrink-0 text-xs text-diamond-400 hover:underline">{{server}}</a>
        {{else}}
          <span class="shrink-0 text-xs text-ink-faint">{{server}}</span>
        {{/if}}
        <span class="shrink-0 text-xs text-ink-faint">{{actor}} · {{ts}}</span>
        {{#if hasLog}}<button class="btn btn-ghost btn-sm shrink-0" data-event-excerpt data-event-id="{{id}}" data-event-type="{{type}}" data-tip="View captured log excerpt">{{{icon 'file-text' 'size-3.5'}}}</button>{{/if}}
      </li>
    {{else}}
      <li class="p-10 text-center text-sm text-ink-faint">No events match these filters.</li>
    {{/each}}
  </ol>
  {{#if events.length}}
  <div class="flex items-center justify-between border-t border-line p-3 text-xs text-ink-faint">
    <span>Showing {{from}}–{{to}} of {{total}} events</span>
    <div class="flex items-center gap-2">
      {{#if prevHref}}<a class="btn btn-ghost btn-sm" href="{{prevHref}}" aria-label="Previous page">←</a>{{else}}<button class="btn btn-ghost btn-sm" disabled aria-label="Previous page">←</button>{{/if}}
      <span>Page {{page}} of {{pages}}</span>
      {{#if nextHref}}<a class="btn btn-ghost btn-sm" href="{{nextHref}}" aria-label="Next page">→</a>{{else}}<button class="btn btn-ghost btn-sm" disabled aria-label="Next page">→</button>{{/if}}
    </div>
  </div>
  {{/if}}
</div>
{{else}}
  {{> empty-state iconName='history' title='No activity yet' message='Every action across every server lands here — starts and stops, backups, updates, player management, with the receipts.'}}
{{/if}}
<script type="module" src="/js/pages/activity.js"></script>

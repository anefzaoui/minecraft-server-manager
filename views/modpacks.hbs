{{> page-header heading="MODPACKS" sub="Browse CurseForge & Modrinth packs and manage installed ones — always version-pinned so restarts never surprise you."}}

<div id="modpacks-page">
  <div class="mb-4 flex flex-wrap items-center gap-2">
    <input class="input min-w-56 max-w-md flex-1" id="packs-q" placeholder="Search modpacks — e.g. Simply Optimized, All the Mods…" autocomplete="off">
    <div class="seg" id="packs-platforms" role="group" aria-label="Search platform">
      <button type="button" class="seg-btn" aria-pressed="true" data-platform="modrinth">Modrinth</button>
      <button type="button" class="seg-btn" aria-pressed="false" data-platform="curseforge">CurseForge</button>
    </div>
    <div class="ml-auto flex gap-2">
      <button class="btn btn-primary" id="packs-install-btn">{{{icon 'plus' 'size-4'}}} Install a pack</button>
      <a href="/settings" class="btn">{{{icon 'key' 'size-4'}}} API keys</a>
    </div>
  </div>

  <div class="hidden" id="packs-results-wrap">
    <h3 class="mb-3 mt-6 text-xs font-semibold uppercase tracking-wider text-ink-faint">Search results</h3>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3" id="packs-results"></div>
  </div>

  <h3 class="mb-3 mt-6 text-xs font-semibold uppercase tracking-wider text-ink-faint">Installed</h3>

  {{#unless packServers.length}}
    {{> empty-state iconName='package' title='No modpacks installed' message='No server is running a managed modpack yet. Search above and hit "Create server", or start from the wizard — installs are always version-pinned so restarts never surprise you.' ctaHref='/servers/new' ctaLabel='Create a server'}}
  {{/unless}}

  <div class="grid gap-4 md:grid-cols-2" id="packs-installed">
    {{#each packServers}}
      <div class="card cursor-pointer p-4 transition hover:border-line-strong hover:shadow-raised" style="border-top: 3px solid {{accent}}"
           data-pack-card data-server-id="{{id}}" data-server-name="{{name}}"
           data-pack-name="{{pack.name}}" data-current="{{pack.version}}" data-latest="{{pack.latest}}">
        <div class="flex items-center gap-3">
          <img src="{{iconSrc this.icon}}" alt="" class="size-10 shrink-0 rounded-md" onerror="this.src='/icons/servers/grass.png'">
          <div class="min-w-0 flex-1">
            <div class="truncate font-semibold">{{pack.name}}</div>
            <div class="text-xs text-ink-faint">{{pack.platform}} · on <a href="/servers/{{id}}" class="text-link hover:underline">{{name}}</a></div>
          </div>
          <span class="chip shrink-0">pinned @ {{pack.version}}</span>
        </div>
        <div class="mt-3 flex items-center gap-2 border-t border-line pt-3 text-sm">
          {{#if updateAvailable}}
            <span class="badge badge-warn">{{pack.latest}} available</span>
            <button class="btn btn-sm ml-auto" data-pack-upgrade>{{{icon 'circle-arrow-up' 'size-3.5'}}} Upgrade…</button>
          {{else}}
            <span class="text-xs text-ok">{{{icon 'check' 'size-3.5'}}} Up to date</span>
            <button class="btn btn-ghost btn-sm ml-auto" data-pack-check>{{{icon 'rotate-cw' 'size-3.5'}}} Check now</button>
          {{/if}}
        </div>
      </div>
    {{/each}}
  </div>
</div>
<script type="module" src="/js/pages/modpacks.js"></script>

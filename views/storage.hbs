{{> page-header heading="STORAGE" sub="Complete visibility over ./data — every byte accounted for, every cleanup previewed."}}

<div class="mb-6 grid gap-4 lg:grid-cols-3">
  <div class="card p-4 lg:col-span-2">
    <div class="flex items-baseline justify-between">
      <h3 class="font-semibold">Disk usage</h3>
      <span class="text-xs text-ink-faint">Last scanned {{storage.lastScan}} · <button class="text-diamond-400 hover:underline" id="storage-rescan">re-scan now</button></span>
    </div>
    <div class="mt-3 flex items-end gap-2">
      <span class="text-3xl font-bold">{{bytes storage.totalUsed}}</span>
      <span class="pb-1 text-sm text-ink-faint">panel data · {{bytes storage.diskFree}} free of {{bytes storage.diskTotal}} on drive</span>
    </div>
    <div class="meter mt-3 h-3"><div class="bg-grass-500" style="width: {{pct storage.totalUsed storage.diskTotal}}%"></div></div>
    <div class="mt-4 flex h-6 w-full overflow-hidden rounded-md" title="Breakdown by category">
      {{#each storage.breakdown}}
        <div class="{{cls}}" style="width: {{width}}%" title="{{label}} — {{bytes size}}"></div>
      {{/each}}
    </div>
    <div class="mt-2 flex flex-wrap gap-3 text-xs text-ink-faint">
      {{#each storage.breakdown}}
        <span><span class="mr-1 inline-block size-2 rounded-sm {{cls}}"></span>{{label}} · {{bytes size}}</span>
      {{/each}}
    </div>
  </div>

  <div class="card p-4">
    <h3 class="mb-2 font-semibold">Growth trend</h3>
    <div class="flex h-24 items-end gap-1">
      {{#each storage.trend}}
        <div class="flex-1 rounded-t bg-diamond-500/70" style="height: {{this}}%"></div>
      {{/each}}
    </div>
    <p class="help">GB used over the last scans. Snapshots recorded on every scan.</p>
  </div>
</div>

<div class="grid gap-4 lg:grid-cols-2">
  <div class="card">
    <div class="border-b border-line p-3 font-semibold">By category</div>
    <div class="overflow-x-auto">
      <table class="table-base">
        <tbody>
          {{#each storage.categories}}
            <tr>
              <td><div class="font-medium">{{name}}</div><div class="font-mono text-xs text-ink-faint">{{path}}</div></td>
              <td class="w-40"><div class="meter"><div class="bg-diamond-400" style="width: {{pct size ../storage.totalUsed}}%"></div></div></td>
              <td class="w-24 text-right text-ink-faint">{{bytes size}}</td>
              <td class="w-10 text-right"><a class="btn btn-ghost btn-sm" href="{{link}}" data-tip="Open in the global file manager">{{{icon 'folder-open' 'size-3.5'}}}</a></td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <div class="space-y-4">
    <div class="card">
      <div class="border-b border-line p-3 font-semibold">One-click cleanup</div>
      <div class="divide-y divide-line">
        {{#each storage.cleanup}}
          <div class="flex items-center gap-3 p-3 text-sm">
            <span class="flex-1">{{action}}{{#if count}} <span class="text-xs text-ink-faint">({{count}} item{{#if (ne count 1)}}s{{/if}})</span>{{/if}}</span>
            <span class="text-xs text-grass-400">frees {{bytes frees}}</span>
            <button class="btn btn-sm" data-cleanup-action="{{key}}" data-cleanup-label="{{action}}" {{#if days}}data-cleanup-days="{{days}}"{{/if}}>Preview…</button>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="card">
      <div class="border-b border-line p-3 font-semibold">Quota status — all instances</div>
      <div class="overflow-x-auto">
        <table class="table-base">
          <tbody>
            {{#each servers}}
              <tr>
                <td><a class="font-medium text-diamond-400 hover:underline" href="/servers/{{id}}">{{name}}</a></td>
                <td class="w-40"><div class="meter"><div class="{{meterColor disk.used disk.quota}}" style="width: {{pct disk.used disk.quota}}%"></div></div></td>
                <td class="w-32 text-right text-xs text-ink-faint">{{bytes disk.used}} / {{bytes disk.quota}}</td>
              </tr>
            {{else}}
              <tr><td class="p-6 text-center text-ink-faint">No servers yet — per-instance quotas appear here once you create one.</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

{{#if storage.largestFiles.length}}
<div class="card mt-6">
  <div class="border-b border-line p-3 font-semibold">Largest files</div>
  <div class="overflow-x-auto">
    <table class="table-base">
      <tbody>
        {{#each storage.largestFiles}}
          <tr>
            <td class="font-mono text-xs">{{path}}</td>
            <td class="w-24 text-right text-ink-faint">{{bytes size}}</td>
            <td class="w-10 text-right"><a class="btn btn-ghost btn-sm" href="{{link}}" data-tip="Open containing folder in the file manager">{{{icon 'folder-open' 'size-3.5'}}}</a></td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
{{else}}
<div class="mt-6">
  {{> empty-state iconName='file-search' title='Nothing indexed yet' message='Run a re-scan from the Disk usage card above to index the largest files under ./data.'}}
</div>
{{/if}}
<script type="module" src="/js/pages/storage.js"></script>

{{> page-header heading="SCHEDULES" sub="Cron-driven automation per server plus the panel's own maintenance tasks."}}

<div class="mb-4 flex flex-wrap items-center gap-2">
  <button class="btn btn-primary" id="schedule-new">{{{icon 'plus' 'size-4'}}} New task</button>
</div>

{{#if schedules.length}}
<div class="card overflow-x-auto">
  <table class="table-base" id="schedules-table">
    <thead><tr><th>Server</th><th>Task</th><th>Cron</th><th class="text-right">Next run</th><th>Enabled</th><th class="text-right"></th></tr></thead>
    <tbody>
      {{#each schedules}}
        <tr data-schedule-row data-schedule-id="{{id}}" data-server-id="{{serverId}}" data-task-type="{{taskType}}" data-task="{{task}}" data-cron="{{cron}}" data-payload="{{json payload}}">
          <td class="{{#if (eq server '— global —')}}text-ink-faint{{/if}}">{{server}}</td>
          <td class="font-medium">{{task}}</td>
          <td class="font-mono text-xs text-ink-faint">{{cron}}</td>
          <td class="text-right text-ink-faint">{{next}}</td>
          <td>
            <label class="msm-toggle"><input type="checkbox" data-schedule-toggle {{#if enabled}}checked{{/if}}><span></span></label>
          </td>
          <td class="text-right"><div class="inline-flex gap-1">
            <button class="btn btn-ghost btn-sm" data-schedule-edit data-tip="Edit (deletes and recreates the schedule)">{{{icon 'pencil' 'size-3.5'}}}</button>
            <button class="btn btn-ghost btn-sm text-redstone-400" data-schedule-delete data-tip="Delete schedule" aria-label="Delete schedule">{{{icon 'x' 'size-3.5'}}}</button>
          </div></td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{else}}
  {{> empty-state iconName='calendar-clock' title='No scheduled tasks yet' message='Automate restarts, backups and console commands on a cron schedule — hit New task above to create the first one.'}}
{{/if}}

<div id="msm-schedule-data" hidden data-servers="{{json serverOptions}}" data-task-types="{{json taskTypes}}"></div>
<script type="module" src="/js/pages/schedules.js"></script>

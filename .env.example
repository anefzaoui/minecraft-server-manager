# Copy to .env and adjust. Every value is optional — the defaults shown work out
# of the box, and a fresh `npm start` is secure with no edits at all.

# Root directory for ALL panel-managed state (DB, server data, backups, library…).
DATA_DIR=./data

# Web UI bind address and port. The default binds to localhost ONLY (127.0.0.1) —
# the panel is reachable just from this machine. Set PANEL_HOST=0.0.0.0 to reach it
# from your LAN; only put it on the internet behind a reverse proxy with TLS.
PANEL_HOST=127.0.0.1
# 25564 sits just below the game-port range (25565+), so your game instances
# number cleanly upward from 25565 without the panel taking a slot in the middle.
PANEL_PORT=25564

# Signs the session cookie and derives the at-rest encryption key for stored API
# keys / RCON passwords. Leave BLANK to have the panel generate a strong random
# secret on first run and persist it at $DATA_DIR/.session-secret. Set it yourself
# only if you want to control the value (e.g. share one across replicas).
SESSION_SECRET=

# Set these when running behind a reverse proxy that terminates TLS.
#   TRUST_PROXY:  proxy hops to trust (usually 1), 'loopback', or a comma-list of
#                 proxy IPs — so req.ip (login rate-limiting) sees the real client.
#   COOKIE_SECURE: 'true' to force the Secure cookie flag over HTTPS, or 'auto' to
#                 let the panel decide from X-Forwarded-Proto (needs TRUST_PROXY set).
TRUST_PROXY=
COOKIE_SECURE=

# Docker endpoint override. Auto-detected per-OS by default (Windows named pipe or
# the unix socket). Set this for rootless Docker, Podman, or a remote daemon, e.g.:
#   unix:///run/user/1000/docker.sock    or    tcp://192.168.1.10:2375
DOCKER_HOST=

# Optional: seed a CurseForge API key on first run (the Settings page can also set
# it). Wrap in single quotes — CF keys often contain $ characters.
CF_API_KEY=

# Docker image repository for Minecraft servers. Override only for a private mirror
# or air-gapped registry; the panel is otherwise an itzg/minecraft-server front-end.
MC_IMAGE_REPO=itzg/minecraft-server

# Starting resource defaults for NEW servers. Leave blank to let the panel pick
# host-aware defaults (a fraction of detected host RAM, falling back to modest
# values). Override if you want a fixed starting point.
DEFAULT_HEAP_MB=
DEFAULT_CONTAINER_MEMORY_MB=
DEFAULT_DISK_QUOTA_GB=

# Port allocation scheme. Game ports are assigned from PORT_GAME_START upward
# (first free); each server's RCON host port is its game port + PORT_RCON_OFFSET;
# Bedrock/Geyser UDP is assigned from PORT_BEDROCK_START upward.
PORT_GAME_START=25565
PORT_RCON_OFFSET=1000
PORT_BEDROCK_START=19132
